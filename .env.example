# Polygon.io — https://polygon.io (free tier supports delayed data; Starter plan for real-time)
VITE_POLYGON_API_KEY=your_polygon_api_key_here

# Tradier — https://developer.tradier.com (sandbox is free)
VITE_TRADIER_TOKEN=your_tradier_token_here
VITE_TRADIER_ACCOUNT_ID=your_account_id_here
# Use 'sandbox' for paper trading, 'live' for real money
VITE_TRADIER_ENV=sandbox
